class Solution:
    def numIslands(self, grid: List[List[str]]) -> int:
        count = 0
        for row in range(len(grid)):
            for col in range(len(grid[0])):
                if grid[row][col] == "1":
                    count += 1
                    def dfs(row, col):
                        if grid[row][col] == "0" or grid[row][col] == "X":
                            return
                        if grid[row][col] == "1":
                            grid[row][col] = "X"
                        dirs = [(0,1), (1,0), (-1,0), (0,-1)]
                        for dx,dy in dirs:
                            if row + dx < 0 or row + dx > len(grid) - 1 or col + dy < 0 or col + dy > len(grid[0]) - 1:
                                continue
                            if grid[row+dx][col+dy] == "1":
                                dfs(row+dx, col+dy)
                        return
                    dfs(row, col)
        return count

        